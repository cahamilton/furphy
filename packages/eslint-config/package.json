{
  "name": "@cahamilton/eslint-config",
  "version": "1.2.3",
  "description": "Configuration for ESLint",
  "author": "Carl Hamilton <github@carlhamilton.dev>",
  "homepage": "https://github.com/cahamilton/furphy#readme",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cahamilton/furphy.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "scripts": {
    "clean": "rm -rfv dist/",
    "build": "tsc",
    "prebuild": "npm run clean && npm run test",
    "prepack": "npm run build",
    "prettier": "prettier --check '**/*.ts'",
    "prettier:fix": "prettier --write '**/*.ts'",
    "test": "npm run prettier"
  },
  "dependencies": {
    "@eslint/js": "^9.39.0",
    "@eslint/json": "^1.0.0",
    "@eslint/markdown": "^7.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.0"
  },
  "devDependencies": {
    "@cahamilton/prettier-config": "^1.2.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0"
  },
  "peerDependencies": {
    "eslint": "^9.39.0",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "prettier": "@cahamilton/prettier-config"
}
